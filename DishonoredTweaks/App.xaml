<Application x:Class="DishonoredTweaks.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />

                <materialDesign:CustomColorTheme BaseTheme="Light"
                                                 PrimaryColor="#5c6f80"
                                                 SecondaryColor="#586a78" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Dishonored-inspired palette: slate blues and muted greens -->
            <SolidColorBrush x:Key="PrimaryHueMidBrush" Color="#5c6f80" />
            <SolidColorBrush x:Key="PrimaryHueMidForegroundBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="PrimaryHueDarkBrush" Color="#586a78" />
            <SolidColorBrush x:Key="PrimaryHueDarkForegroundBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="PrimaryHueLightBrush" Color="#98a6af" />
            <SolidColorBrush x:Key="PrimaryHueLightForegroundBrush" Color="#FFFFFF" />

            <Color x:Key="MaterialDesign.Primary.Foreground">#FFFFFF</Color>
            <SolidColorBrush x:Key="MaterialDesign.Brush.Primary.Foreground"
                             Color="{StaticResource MaterialDesign.Primary.Foreground}" />

            <Style TargetType="ScrollBar" x:Key="ModernScrollBar">
                <Setter Property="Width" Value="8"/>
                <Setter Property="Margin" Value="0"/>
                <Setter Property="Opacity" Value="0.7"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid Background="Transparent">
                                <Track x:Name="PART_Track"
                                       Orientation="{TemplateBinding Orientation}"
                                       IsDirectionReversed="true"
                                       VerticalAlignment="Stretch"
                                       HorizontalAlignment="Stretch">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.LineUpCommand"
                                                      Style="{x:Null}"
                                                      Height="0" Width="0"/>
                                    </Track.DecreaseRepeatButton>

                                    <Track.Thumb>
                                        <Thumb x:Name="Thumb">
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Border x:Name="ThumbBorder"
                                                            Background="#666"
                                                            CornerRadius="4"
                                                            Opacity="0.5"
                                                            Margin="2">
                                                        <Border.Effect>
                                                            <DropShadowEffect BlurRadius="4"
                                                                              Opacity="0.2"
                                                                              ShadowDepth="0"/>
                                                        </Border.Effect>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="ThumbBorder"
                                                                    Property="Background"
                                                                    Value="{DynamicResource PrimaryHueMidBrush}" />
                                                            <Setter TargetName="ThumbBorder"
                                                                    Property="Opacity"
                                                                    Value="0.9" />
                                                        </Trigger>
                                                        <Trigger Property="IsDragging" Value="True">
                                                            <Setter TargetName="ThumbBorder"
                                                                    Property="Background"
                                                                    Value="{DynamicResource PrimaryHueDarkBrush}" />
                                                            <Setter TargetName="ThumbBorder"
                                                                    Property="Opacity"
                                                                    Value="1" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>

                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.LineDownCommand"
                                                      Style="{x:Null}"
                                                      Height="0" Width="0"/>
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
